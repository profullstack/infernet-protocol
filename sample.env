# Next.js runtime
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (self-hosted OR cloud)
# Self-hosted: run `supabase start` and use http://127.0.0.1:54321 with the local service-role key.
# Cloud: point at https://<project-ref>.supabase.co with the service-role key from the dashboard.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional query tuning
SUPABASE_SCHEMA=public
INFERNET_DEFAULT_PAGE_SIZE=25

# Payments (CoinPayPortal)
COINPAYPORTAL_API_KEY=
COINPAYPORTAL_API_BASE_URL=https://api.coinpayportal.com/v1
COINPAYPORTAL_WEBHOOK_SECRET=

# NVIDIA NIM fallback inference (build.nvidia.com)
# When the P2P network has no live providers, chat jobs fall back to
# NVIDIA's hosted OpenAI-compatible endpoint so the UX never breaks
# during the bootstrap phase. Leave blank to disable.
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_API_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_DEFAULT_MODEL=meta/llama-3.3-70b-instruct
