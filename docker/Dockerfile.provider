# Infernet Protocol — provider node image (thin shim).
#
# This image is deliberately minimal: ubuntu base + curl + bash + sudo,
# nothing else. On container start, the entrypoint pipes the universal
# cloud-init bootstrap from the control plane through bash, which:
#
#   - installs Ollama
#   - installs the Infernet CLI (via the official install.sh)
#   - pulls the configured model
#   - runs `infernet init`, `login --token`, `setup --yes`
#   - tail-execs `infernet start --foreground`
#
# Why a shim instead of baking everything in:
#   - the cloud-init flow is the source of truth — one path for Docker,
#     bare-metal, RunPod, DigitalOcean. Updating the bootstrap doesn't
#     require rebuilding + republishing the image.
#   - image stays small + fast to pull
#   - operators always get the latest CLI on container restart, without
#     us shipping a new image tag
#
# Trade-off: ~2-5 min cold start (network installs Ollama + Node + CLI
# + pulls the model). Once the container's running, restarts are fast
# because Ollama and the CLI persist in the layer the cloud-init wrote.
# For a faster cold-start tier, build a "fat" image variant later.
#
# Configuration is purely env-var driven (see cloud-init for the list):
#
#   INFERNET_BEARER          24h CLI bearer (mint at /deploy)
#   INFERNET_CONTROL_PLANE   default: https://infernetprotocol.com
#   INFERNET_MODEL           default: qwen2.5:7b
#   INFERNET_NODE_ROLE       default: provider
#   INFERNET_PUBLIC_PORT     default: 46337  (P2P listener)
#   PORT                     default: 8080   (HTTP /healthz)

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Minimal prerequisites the cloud-init expects to find. Everything
# else (Node, Ollama, the CLI workspace) is installed at runtime.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        curl ca-certificates bash sudo \
        pciutils iproute2 hostname \
    && rm -rf /var/lib/apt/lists/*

ENV PORT=8080 \
    INFERNET_PUBLIC_PORT=46337 \
    INFERNET_CONTROL_PLANE=https://infernetprotocol.com \
    INFERNET_MODEL=qwen2.5:7b \
    INFERNET_NODE_ROLE=provider \
    INFERNET_NONINTERACTIVE=1

# 8080 = HTTP /healthz (daemon-side), 46337 = P2P listener
EXPOSE 8080 46337

# Health: probe /healthz once the daemon comes up. start-period gives
# cloud-init time to install everything before failing the probe.
HEALTHCHECK --interval=30s --timeout=5s --start-period=300s --retries=3 \
    CMD curl -fsS http://127.0.0.1:${PORT}/healthz || exit 1

# That's it. The whole bootstrap is one curl. Override via:
#   docker run ... bash -i   # debug shell instead of bootstrap
CMD ["bash", "-c", "curl -fsSL ${INFERNET_CONTROL_PLANE:-https://infernetprotocol.com}/api/deploy/cloud-init | bash"]
