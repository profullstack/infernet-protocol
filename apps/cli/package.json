{
  "name": "@infernetprotocol/cli",
  "version": "0.1.0",
  "description": "GPU-node CLI / daemon for the Infernet Protocol — register a GPU server with a Supabase control plane and start earning.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "infernet": "./index.js"
  },
  "main": "./index.js",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "index.js",
    "commands/**/*.js",
    "lib/**/*.js",
    "examples/**/*.js",
    "README.md"
  ],
  "engines": { "node": ">=18" },
  "scripts": {
    "start": "node ./index.js"
  },
  "dependencies": {
    "@infernetprotocol/auth": "workspace:*",
    "@infernetprotocol/config": "workspace:*",
    "@infernetprotocol/engine": "workspace:*",
    "@infernetprotocol/gpu": "workspace:*",
    "dotenv": "^16.4.7"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/profullstack/infernet-protocol.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/profullstack/infernet-protocol#readme",
  "keywords": [
    "infernet",
    "gpu",
    "inference",
    "p2p",
    "crypto",
    "cli",
    "daemon"
  ]
}
