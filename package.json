{
  "name": "infernet-protocol",
  "version": "0.1.0",
  "private": true,
  "description": "Infernet: A Peer-to-Peer Distributed GPU Inference Protocol",
  "license": "ISC",
  "author": "Profullstack, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/profullstack/infernet-protocol.git"
  },
  "homepage": "https://infernetprotocol.com",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
