{
  "name": "infernet-protocol",
  "private": true,
  "version": "2.0.0",
  "description": "Infernet Protocol monorepo",
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev": "pnpm --filter @infernet/web dev",
    "build": "pnpm --filter @infernet/web build",
    "start": "pnpm --filter @infernet/web start",
    "cli": "pnpm --filter @infernet/cli exec infernet",
    "test": "pnpm -r --parallel test",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:db:reset": "supabase db reset",
    "supabase:login": "supabase login",
    "supabase:link": "supabase link",
    "supabase:db:push": "supabase db push"
  },
  "devDependencies": {
    "@infernet/cli": "workspace:*",
    "vitest": "^3.0.8"
  }
}
